{
  "name": "chrome-extensions-rayshar",
  "private": true,
  "description": "Monorepo for Rayshar Chrome extensions",
  "packageManager": "pnpm@10.29.3",
  "scripts": {
    "build": "turbo run build",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "type-check": "turbo run type-check",
    "package": "turbo run package",
    "clean": "turbo run clean",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "quality": "turbo run type-check lint test",
    "gen:extension": "turbo gen extension",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@turbo/gen": "^2.4.0",
    "@vitest/coverage-v8": "^4.0.18",
    "lefthook": "^2.1.2",
    "turbo": "^2.4.0",
    "vitest": "^4.0.18"
  }
}
