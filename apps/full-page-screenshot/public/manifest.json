{
  "manifest_version": 3,
  "name": "Full Page Screenshot (Rayshar)",
  "version": "2.1.0",
  "description": "Capture full-page screenshots with scroll-and-stitch — supports inner scrollable containers",
  "permissions": ["activeTab", "scripting", "downloads", "webNavigation"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
