{
  "manifest_version": 3,
  "name": "NightShift — Dark Mode",
  "version": "1.0.0",
  "description": "Dark mode for any website — CSS filter inversion with smart detection",
  "permissions": ["storage", "alarms", "downloads"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "NightShift"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
