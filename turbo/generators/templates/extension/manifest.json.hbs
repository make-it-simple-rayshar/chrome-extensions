{
  "manifest_version": 3,
  "name": "{{ displayName }} (Rayshar)",
  "version": "0.0.1",
  "description": "{{ description }}",
  "permissions": [{{{json-permissions permissions}}}],
  "action": {
{{#if hasPopup}}
    "default_popup": "popup.html",
{{/if}}
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }{{#if hasBackground}},
  "background": {
    "service_worker": "background.js"
  }{{/if}}{{#if hasContentScript}},
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]{{/if}},
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
