{
  "name": "@rayshar/{{ name }}",
  "version": "0.0.1",
  "private": true,
  "description": "{{ description }}",
  "scripts": {
    "build": "vite build{{#if hasBackground}} && vite build --config vite.config.background.ts{{/if}}{{#if hasContentScript}} && vite build --config vite.config.content.ts{{/if}}",
    "dev": "concurrently \"vite build --watch\"{{#if hasBackground}} \"vite build --watch --config vite.config.background.ts\"{{/if}}{{#if hasContentScript}} \"vite build --watch --config vite.config.content.ts\"{{/if}}",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist *.zip",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "package": "node ../../scripts/package-extension.mjs"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@rayshar/tsconfig": "workspace:*",
    "@tailwindcss/vite": "^4.0.0",
    "@types/chrome": "latest",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "concurrently": "^9.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.0.0",
    "vite": "^6.0.0"
  }
}
